{
  "name": "cn-messaging-context",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Codex plugin, MCP server, and connector service for Feishu, Lark, DingTalk messages, and DingTalk OA approvals.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev:mcp": "tsx src/mcp/server.ts",
    "dev:connector": "tsx src/connector/server.ts",
    "start:mcp": "node dist/mcp/server.js",
    "start:connector": "node dist/connector/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.4",
    "express": "^4.19.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
