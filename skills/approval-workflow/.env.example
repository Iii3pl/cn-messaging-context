# 审批工作流环境变量配置模板
# 复制此文件为 .env 并填写实际值

# ============
# 钉钉配置
# ============

# 当前用户的钉钉 User ID
DINGTALK_USER_ID=your_user_id_here

# 当前用户的钉钉 Union ID
DINGTALK_UNION_ID=your_union_id_here

# 钉钉 App Key (可选，默认使用 dws cli 的配置)
DINGTALK_APP_KEY=dingffxw3wme8pjq8km8

# 钉钉 App Secret (可选，默认使用 dws cli 的配置)
DINGTALK_APP_SECRET=your_app_secret_here

# ============
# 薪福通配置
# ============

# opencli session 名称 (运行 `opencli browser list` 查看)
XFT_SESSION_NAME=your_session_name_here

# 薪福通数据库路径
XFT_DB_PATH=~/.hermes/data/cmb_approvals.db

# 薪福通主页 URL
XFT_HOME_URL=https://xft.cmbchina.com/TripMainWeb/#/form-app/approval

# ============
# Hermes 配置
# ============

# Hermes 主目录 (包含 skills 和 scripts)
# 默认: ~/.hermes
HERMES_HOME=~/.hermes

# ============
# 其他配置
# ============

# 日志级别 (debug | info | warn | error)
LOG_LEVEL=info

# 是否启用调试模式 (true | false)
DEBUG_MODE=false
